# =============================================================================
# Kalpixk — Variables de entorno
# =============================================================================
#
# INSTRUCCIONES:
#   1. Copiar este archivo como .env:
#      cp .env.example .env
#
#   2. Completar los valores marcados con ← en el archivo .env
#
#   3. NUNCA hacer git add .env — el .gitignore lo excluye automáticamente
#      Pero sí hacer git add .env.example con los campos vacíos
#
# CUÁLES SON OBLIGATORIAS:
#   Para demo sin GPU:  Solo TELEGRAM_TOKEN
#   Para GPU AMD:       TELEGRAM_TOKEN + AMD_DROPLET_IP
#   Para Base44 API:    BASE44_API_KEY
#   Para WhatsApp:      TWILIO_* (opcional)
#
# =============================================================================

# =============================================================================
# TELEGRAM — Alertas de seguridad y control desde el móvil
# =============================================================================
#
# CÓMO OBTENER EL TOKEN:
#   1. Abrir Telegram y buscar @BotFather
#   2. Enviar: /newbot
#   3. Seguir las instrucciones (nombre del bot, username)
#   4. BotFather te dará un token como: 1234567890:ABCdefGHIjklMNOpqrSTUVwxyz
#
# CÓMO OBTENER TU CHAT_ID:
#   1. Buscar @userinfobot en Telegram
#   2. Enviar cualquier mensaje
#   3. El bot responde con tu ID numérico
#
TELEGRAM_TOKEN=

# ID del usuario/chat que recibirá las alertas de Kalpixk
# Tu ID es 8247886073 (verificado en las capturas)
TELEGRAM_CHAT_ID=your_numeric_chat_id

# =============================================================================
# BASE44 — API para historial de alertas y dashboard persistente
# =============================================================================
#
# CÓMO OBTENER LA API KEY:
#   1. Ir a https://app.base44.com
#   2. Abrir tu agente Kalpixk
#   3. Ver la sección "API Reference"
#   4. La API key se muestra en la documentación
#
# PARA QUÉ SE USA:
#   kalpixk_monitor.py guarda cada alerta detectada en Base44
#   Así el dashboard de Base44 puede mostrar el historial real
#
BASE44_API_KEY=

# ID del agente Kalpixk en Base44 (ya configurado)
BASE44_AGENT_ID=your_agent_id

# ID de la conversación donde se guardan las alertas
# (crear una primera vez manualmente o dejar vacío para crear automáticamente)
BASE44_CONV_ID=

# =============================================================================
# AMD DEVELOPER CLOUD — Droplet MI300X
# =============================================================================
#
# FLUJO DE TRABAJO CON EL DROPLET:
#   1. Crear droplet en https://amd.digitalocean.com
#      → Create GPU Droplet → MI300X → Quick Start ROCm
#      → Toma 3-5 minutos en crearse
#
#   2. Copiar la IP del droplet aquí
#
#   3. Correr el setup: ssh root@IP y luego ./sesion_amd.sh
#
#   4. Actualizar KALPIXK_API_URL con la IP nueva
#
#   5. ⚠️ DESTRUIR el droplet cuando termines la sesión
#      AMD cobra $1.99/hr aunque esté apagado
#      Créditos disponibles: ~$46 (vencen Mayo 3, 2026)
#
AMD_DROPLET_IP=
# La URL se construye automáticamente con la IP
KALPIXK_API_URL=http://${AMD_DROPLET_IP}:8000

# =============================================================================
# WHATSAPP (via Twilio) — Opcional
# =============================================================================
#
# CÓMO OBTENER LAS CREDENCIALES:
#   1. Crear cuenta en https://www.twilio.com
#   2. Activar el Sandbox de WhatsApp
#   3. Account SID y Auth Token están en el dashboard principal
#
# COSTO: Twilio cobra por mensaje (~$0.005 USD/mensaje)
# Para el hackathon Telegram es suficiente y es gratis
#
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Número de Twilio para WhatsApp (formato internacional)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# =============================================================================
# GITHUB — Para que KiloKlawKynos haga commits automáticos
# =============================================================================
#
# CÓMO OBTENER:
#   https://github.com/settings/tokens
#   → Generate new token (classic)
#   → Scopes: repo (completo)
#
# PARA QUÉ SE USA:
#   KiloKlawKynos puede hacer commits al repositorio desde Telegram
#   cuando le dices "actualiza el README" o "haz push del monitor"
#
GITHUB_TOKEN=
GITHUB_REPO=JULIANJUAREZMX01/Wasm-Kalpixk_IA_DevOps

# =============================================================================
# CONFIGURACIÓN DEL MONITOR
# =============================================================================

# Score mínimo [0.0-1.0] para enviar alerta a Telegram
# 0.65 = eventos altos y críticos (recomendado para producción)
# 0.45 = también eventos medianos (más alertas, más ruido)
ALERT_THRESHOLD=0.65

# Segundos entre checks del monitor
# 60 = verificar cada minuto
# 300 = verificar cada 5 minutos (menor carga)
CHECK_INTERVAL=60

# =============================================================================
# LLM EXPLAINER — Llama 70B para explicaciones de alertas
# =============================================================================
#
# Solo disponible cuando el droplet AMD está activo
# El LLM corre localmente en el MI300X via vLLM
# Costo: $0 por query (incluido en el costo del droplet)
#
LLM_API_URL=http://${AMD_DROPLET_IP}:8001

# =============================================================================
# ENTORNO
# =============================================================================

# development = logs verbose, recarga automática, CORS permisivo
# production  = logs mínimos, sin recarga, CORS estricto
KALPIXK_ENV=development

# DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
