# Wasm-Kalpixk_IA_DevOps — Variables de entorno
# Copiar a .env y configurar

# ── AMD / GPU ────────────────────────────────────────────────
AMD_VLLM_URL=http://<ip-droplet>:8000/v1
ROCM_VISIBLE_DEVICES=0

# ── LLM Providers (fallback) ─────────────────────────────────
GROQ_API_KEY=your_groq_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here

# ── Telegram Bot ─────────────────────────────────────────────
# Bot: @SuperAsistenteSacBot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ── WhatsApp / Twilio ────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
WHATSAPP_TO=whatsapp:+521234567890

# ── API / Monitor ────────────────────────────────────────────
PORT=8000
ENV=production
LOG_LEVEL=INFO
MONITOR_INTERVAL=30

# ── WASM ─────────────────────────────────────────────────────
WASM_MODULES_PATH=./wasm_modules
WASM_MEMORY_PAGES=256
