# Wasm-Kalpixk_IA_DevOps — Variables de entorno

# AMD / GPU
AMD_VLLM_URL=http://<ip-droplet>:8000/v1
ROCM_VISIBLE_DEVICES=0

# LLM Providers (fallback cuando GPU apagada)
GROQ_API_KEY=your_groq_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here

# Notifications
TELEGRAM_BOT_TOKEN=your_telegram_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# API
PORT=8000
ENV=development
LOG_LEVEL=INFO

# WASM
WASM_MODULES_PATH=./wasm_modules
WASM_MEMORY_PAGES=256
